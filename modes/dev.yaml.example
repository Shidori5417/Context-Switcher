# Geliştirme Modu — Örnek Konfigürasyon
# Bu dosyayı ~/.context-switcher/modes/dev.yaml olarak kopyalayın ve düzenleyin.

name: "Geliştirme Modu"
icon: "💻"
hotkey: "Ctrl+Alt+D"

processes:
  start:
    - vscode
    - docker@
  suspend:
    - discord
    - steam
    - slack

layout:
  workspace: 2
  arrangement: main-secondary
  primary_app: vscode

browser:
  profile: Work
  restore_session: true
  tab_groups:
    - name: Docs
      tabs:
        - "https://docs.python.org"
        - "https://hub.docker.com"
    - name: Project
      tabs:
        - "https://github.com"

environment:
  volume: 40
  notifications:
    mute:
      - discord
      - slack
    allow:
      - terminal
  music:
    app: spotify
    playlist: "Deep Focus"
