# Ders/Çalışma Modu — Örnek Konfigürasyon

name: "Ders Modu"
icon: "📚"
hotkey: "Ctrl+Alt+S"

processes:
  start:
    - notion
  suspend:
    - discord
    - steam
    - slack
    - telegram

layout:
  workspace: 1
  arrangement: split-left-right
  primary_app: notion

browser:
  profile: Personal
  restore_session: false
  tab_groups:
    - name: Study
      tabs:
        - "https://chat.openai.com"
        - "https://scholar.google.com"
    - name: Course
      tabs:
        - "https://coursera.org"

environment:
  volume: 20
  notifications:
    mute:
      - discord
      - telegram
      - slack
    allow:
      - notion
  music:
    app: spotify
    playlist: "Lo-Fi Study Beats"
